# Copy to .env in the repository root (never commit real keys).
# Groq: https://console.groq.com/keys
#
# On Streamlit Community Cloud, set the same keys under App settings → Secrets
# (see .streamlit/secrets.example.toml). The app copies secrets into the
# process environment on startup so GROQ_* variables work the same as locally.

GROQ_API_KEY=
# Optional — default is llama-3.1-8b-instant
# GROQ_MODEL=llama-3.1-8b-instant

# Optional LLM routing (auto/groq/gemini). Gemini falls back to Groq on errors when Groq is configured.
# LLM_PROVIDER=auto
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
#
# RAG: FAISS index is the default (data/rag/faiss.index + chunks.json from scripts/build_rag_index.py).
# Optional Chroma store: run scripts/build_chroma_store.py → data/rag/chroma_store/ — select "chroma"
# in Deep Analysis → Agent runtime. No extra env vars required.

# Optional — Hugging Face token if you use a gated embedding model
# HUGGINGFACE_HUB_TOKEN=

# Optional — override model cache directory (defaults to repo .cache/huggingface)
# HF_HOME=
